# Copy to /etc/ddns/ddns.env on the RPi and fill in real values.
# Never commit the real file — it's in .gitignore.

# Cloudflare API token with Zone:DNS
CF_API_TOKEN=your-cloudflare-api-token-here

# Zone ID — find it on the Cloudflare dashboard under domain.com
CF_ZONE_ID=your-zone-id-here

# The A record to keep updated
CF_RECORD_NAME=yourdomain.com

# DNS TTL in seconds for the A record
CF_TTL=60

# How often to check for IP changes, in seconds
DDNS_INTERVAL=300
